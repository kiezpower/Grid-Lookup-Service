{
  "name": "@grid-lookup/backend",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "bun run src/db/migrate.ts",
    "mastr:import": "bun run src/scripts/import-mastr.ts",
    "mastr:parse": "bun run src/scripts/parse-mastr.ts",
    "mastr:parse-json": "bun run src/scripts/parse-mastr-json.ts",
    "test": "bun test --isolate"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "drizzle-orm": "^0.30.0",
    "elysia": "^1.4.28",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.20.0",
    "typescript": "^5.8.3"
  }
}
